(text "This block deserializes TDM-channels one by one" (rect 736 696 1019 709)(font "DejaVu Sans Condensed" (font_size 8)))
(text "and stores up to 26 channels to the parallel output" (rect 736 712 1027 725)(font "DejaVu Sans Condensed" (font_size 8)))
(text "RAM-Writer that takes up to 26 audio-samples and writes" (rect 1248 648 1581 661)(font "DejaVu Sans Condensed" (font_size 8)))
(text "them to the desired RAM-address" (rect 1248 664 1442 677)(font "DejaVu Sans Condensed" (font_size 8)))
